---
interface Props {
  prefix?: string;
  value?: string | string[];
}

const { prefix, value } = Astro.props;

const items = Array.isArray(value) ? value : null;
const hasContent = Array.isArray(value) ? value.length > 0 : Boolean(value);
const lead = prefix ? `${prefix} ` : "";
---
{hasContent && (
  <span class="text-(--text-subtle)">{lead}{items ? items.map((child, index) => (
    <Fragment><span class="whitespace-nowrap">{child}</span>{index < items.length - 1 ? ", " : null}</Fragment>
  )) : value}</span>
)}
